# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit your actual API key.

# Required: Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Override the Claude model used for PDF extraction
# Default: claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-6

# Optional: Override file paths (defaults are relative to repo root)
# WEATHER_DB_PATH=db/weather.db
# WEATHER_PDF_DIR=data/pdf
# WEATHER_CSV_DIR=data/csv
